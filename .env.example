PORT=3000

# DAX88 serial adapter
DAX88_SERIAL_PORT=/dev/ttyUSB0
DAX88_SERIAL_BAUD_RATE=9600
DAX88_SERIAL_DATA_BITS=8
DAX88_SERIAL_PARITY=none
DAX88_SERIAL_STOP_BITS=1
DAX88_SERIAL_OPEN_RETRIES=3
DAX88_SERIAL_OPEN_RETRY_MS=500
DAX88_INTER_WRITE_DELAY_MS=50
DAX88_QUEUE_TASK_TIMEOUT_MS=2500
DAX88_MONITOR_INTERVAL_MS=3000
# DAX88_SERIAL_DISABLED=true

# Up2Stream endpoint
UP2STREAM_IP=192.168.1.55
# alternatively set explicit URL
# UP2STREAM_BASE_URL=http://192.168.1.55
UP2STREAM_POLL_INTERVAL_MS=5000
UP2STREAM_TIMEOUT_MS=4000
UP2STREAM_CACHE_TTL_MS=20000

# auth
API_AUTH_TOKEN=replace-with-long-random-token
DASHBOARD_LOGIN_PASSWORD=replace-with-long-random-password
BROWSER_TOKEN_TTL_MS=300000

# control throttling
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=60
